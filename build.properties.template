# Local build configuration template
# Copy this file to build.properties and adjust the values.
# build.properties is NOT tracked by git.

# Set to true to automatically install/update nixlper locally after a successful build.
ENABLE_LOCAL_INSTALL=false

# Target folder for the local install/update.
LOCAL_INSTALL_FOLDER=/opt/nixlper

# Install mode:
#   install  - full reinstall (runs nixlper.sh install)
#   update   - incremental update (runs nixlper.sh update)
LOCAL_INSTALL_MODE=update
